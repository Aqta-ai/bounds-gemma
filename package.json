{
  "name": "bounds-gemma",
  "version": "0.1.3",
  "description": "On-device Gemma 4 contextual PHI redaction toolkit for HIPAA Safe Harbor de-identification. Runs locally via Ollama (browser WebLLM path wired for when MLC ships a Gemma 4 build). Never on a server.",
  "license": "Apache-2.0",
  "type": "module",
  "private": false,
  "author": "Anya Chueayen <hello@aqta.ai>",
  "homepage": "https://github.com/Aqta-ai/bounds-gemma#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Aqta-ai/bounds-gemma.git"
  },
  "bugs": {
    "url": "https://github.com/Aqta-ai/bounds-gemma/issues"
  },
  "keywords": [
    "gemma",
    "gemma-4",
    "phi",
    "pii",
    "hipaa",
    "redaction",
    "privacy",
    "on-device",
    "webllm",
    "ollama",
    "healthcare",
    "ai",
    "llm"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./parser": {
      "types": "./dist/workers/gemmaParse.d.ts",
      "import": "./dist/workers/gemmaParse.js"
    },
    "./worker": {
      "types": "./dist/workers/gemma.worker.d.ts",
      "import": "./dist/workers/gemma.worker.js"
    },
    "./pipeline": {
      "types": "./dist/pipeline/GemmaWorker.d.ts",
      "import": "./dist/pipeline/GemmaWorker.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "NOTICE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "prepublishOnly": "npm run build && npm test",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "example:ollama": "tsx examples/runOllama.ts",
    "example:webllm": "echo 'Open examples/webllm.html in a browser (Chrome + WebGPU + cross-origin-isolated headers)'"
  },
  "devDependencies": {
    "@mlc-ai/web-llm": "^0.2.83",
    "@types/node": "^20.12.7",
    "tsx": "^4.7.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "peerDependencies": {
    "@mlc-ai/web-llm": "^0.2.79"
  },
  "peerDependenciesMeta": {
    "@mlc-ai/web-llm": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  }
}
